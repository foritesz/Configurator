name: dockercompose434550024337170792
services:
  backend:
    build:
      context: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom
      dockerfile: BackEnd/Dockerfile
    depends_on:
      mongo:
        condition: service_healthy
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      LOG_DIR: /app/Log
      MONGODB_DB: wotdb
      MONGODB_URI: mongodb://mongo:27017/wotdb
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "9190"
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Users\Wqeesda/.aspnet/https
        target: /https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\BackEnd\Logs
        target: /app/Logs
        bind:
          create_host_path: true
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\BackEnd\Repositories\TestXml
        target: /app/TestXml
        bind:
          create_host_path: true
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\BackEnd\Repositories\Bonus
        target: /app/Bonus
        bind:
          create_host_path: true
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\BackEnd\Repositories\TankData
        target: /app/Repositories
        bind:
          create_host_path: true
  frontend:
    build:
      context: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom
      dockerfile: FrontEnd/Dockerfile
    depends_on:
      backend:
        condition: service_started
        required: true
    environment:
      BACKEND_URL: http://localhost:9190
    networks:
      default: null
    ports:
      - mode: ingress
        target: 80
        published: "3300"
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Users\Wqeesda/.aspnet/https
        target: /https
        bind:
          create_host_path: true
  mongo:
    healthcheck:
      test:
        - CMD-SHELL
        - exit 0
    image: mongo:latest
    networks:
      default: null
    ports:
      - mode: ingress
        target: 27017
        published: "27017"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: volume
        source: mongo-data
        target: /data/db
        volume: {}
networks:
  default:
    name: dockercompose434550024337170792_default
volumes:
  mongo-data:
    name: dockercompose434550024337170792_mongo-data