name: dockercompose434550024337170792
services:
  backend:
    build:
      context: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom
      dockerfile: BackEnd/Dockerfile
      args:
        BUILD_CONFIGURATION: Debug
        LAUNCHING_FROM_VS: "true"
      labels:
        com.microsoft.created-by: visual-studio
        com.microsoft.visual-studio.project-name: BackEnd
    depends_on:
      mongo:
        condition: service_healthy
        required: true
    entrypoint:
      - dotnet
      - --roll-forward
      - Major
      - /VSTools/DistrolessHelper/DistrolessHelper.dll
      - --wait
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      LOG_DIR: /app/Log
      MONGODB_DB: wotdb
      MONGODB_URI: mongodb://mongo:27017/wotdb
    labels:
      com.microsoft.visual-studio.project-name: BackEnd
      com.microsoft.visualstudio.debuggee.arguments: ' --additionalProbingPath /.nuget/packages --additionalProbingPath /.nuget/fallbackpackages  "/app/BackEnd.dll"'
      com.microsoft.visualstudio.debuggee.killprogram: dotnet --roll-forward Major /VSTools/DistrolessHelper/DistrolessHelper.dll --stop dotnet
      com.microsoft.visualstudio.debuggee.program: dotnet
      com.microsoft.visualstudio.debuggee.workingdirectory: /app
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "9190"
        protocol: tcp
    tty: true
    volumes:
      - type: bind
        source: C:\Users\Wqeesda/.aspnet/https
        target: /https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\BackEnd\Logs
        target: /app/Logs
        bind:
          create_host_path: true
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\BackEnd\Repositories\TestXml
        target: /app/TestXml
        bind:
          create_host_path: true
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\BackEnd\Repositories\Bonus
        target: /app/Bonus
        bind:
          create_host_path: true
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\BackEnd\Repositories\TankData
        target: /app/Repositories
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\vsdbg\vs2017u5
        target: /remote_debugger
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming\ASP.NET\Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming\ASP.NET\Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming\Microsoft\UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming\Microsoft\UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\2022\Community\MSBuild\Sdks\Microsoft.Docker.Sdk\tools\linux-x64\net8.0
        target: /VSTools
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\2022\Community\Common7\IDE\CommonExtensions\Microsoft\HotReload
        target: /HotReloadAgent
        read_only: true
        bind:
          create_host_path: true
  frontend:
    build:
      context: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom
      dockerfile: FrontEnd/Dockerfile
      args:
        BUILD_CONFIGURATION: Debug
        LAUNCHING_FROM_VS: "true"
      labels:
        com.microsoft.created-by: visual-studio
        com.microsoft.visual-studio.project-name: FrontEnd
    depends_on:
      backend:
        condition: service_started
        required: true
    entrypoint:
      - dotnet
      - --roll-forward
      - Major
      - /VSTools/DistrolessHelper/DistrolessHelper.dll
      - --wait
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_URLS: http://0.0.0.0:8080
    labels:
      com.microsoft.visual-studio.project-name: FrontEnd
      com.microsoft.visualstudio.debuggee.arguments: ' --additionalProbingPath /.nuget/packages --additionalProbingPath /.nuget/fallbackpackages  "/app/FrontEnd.dll"'
      com.microsoft.visualstudio.debuggee.killprogram: dotnet --roll-forward Major /VSTools/DistrolessHelper/DistrolessHelper.dll --stop dotnet
      com.microsoft.visualstudio.debuggee.program: dotnet
      com.microsoft.visualstudio.debuggee.workingdirectory: /app
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "3300"
        protocol: tcp
    tty: true
    volumes:
      - type: bind
        source: C:\Users\Wqeesda/.aspnet/https
        target: /https
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\vsdbg\vs2017u5
        target: /remote_debugger
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming\ASP.NET\Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming\ASP.NET\Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming\Microsoft\UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming\Microsoft\UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\2022\Community\MSBuild\Sdks\Microsoft.Docker.Sdk\tools\linux-x64\net8.0
        target: /VSTools
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\2022\Community\Common7\IDE\CommonExtensions\Microsoft\HotReload
        target: /HotReloadAgent
        read_only: true
        bind:
          create_host_path: true
  mongo:
    healthcheck:
      test:
        - CMD-SHELL
        - exit 0
    image: mongo:latest
    networks:
      default: null
    ports:
      - mode: ingress
        target: 27017
        published: "27017"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: volume
        source: mongo-data
        target: /data/db
        volume: {}
networks:
  default:
    name: dockercompose434550024337170792_default
volumes:
  mongo-data:
    name: dockercompose434550024337170792_mongo-data