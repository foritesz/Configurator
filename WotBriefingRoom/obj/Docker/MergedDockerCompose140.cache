name: dockercompose434550024337170792
services:
  backend:
    build:
      context: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom
      dockerfile: BackEnd/Dockerfile
    depends_on:
      mongo:
        condition: service_healthy
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
      MONGODB_DB: wotdb
      MONGODB_URI: mongodb://mongo:27017/wotdb
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "9191"
        protocol: tcp
      - mode: ingress
        target: 8080
        published: "9090"
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\BackEnd\Logs
        target: /app/Logs
        bind:
          create_host_path: true
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\BackEnd\TestXml
        target: /app/TestXml
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\BackEnd\Bonus
        target: /app/Bonus
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming/Microsoft/UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming/Microsoft/UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming/ASP.NET/Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Wqeesda\AppData\Roaming/ASP.NET/Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
  frontend:
    build:
      context: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom
      dockerfile: FrontEnd/Dockerfile
    depends_on:
      backend:
        condition: service_started
        required: true
    environment:
      BACKEND_URL: http://backend:8080
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "3301"
        protocol: tcp
      - mode: ingress
        target: 8080
        published: "3000"
        protocol: tcp
  mongo:
    healthcheck:
      test:
        - CMD-SHELL
        - exit 0
    image: mongo:latest
    networks:
      default: null
    ports:
      - mode: ingress
        target: 27017
        published: "27017"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: volume
        source: mongo-data
        target: /data/db
        volume: {}
networks:
  default:
    name: dockercompose434550024337170792_default
volumes:
  mongo-data:
    name: dockercompose434550024337170792_mongo-data