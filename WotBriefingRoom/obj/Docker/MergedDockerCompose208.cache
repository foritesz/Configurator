name: dockercompose434550024337170792
services:
  backend:
    build:
      context: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom
      dockerfile: BackEnd/Dockerfile
    container_name: wot-backend
    depends_on:
      mongo:
        condition: service_started
        required: true
    environment:
      LOG_DIR: /app/Logs
      MONGODB_DB: wotdb
      MONGODB_URI: mongodb://mongo:27017
      REPOSITORIES_ROOT: /app/Repositories
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8080"
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\Repositories
        target: /app/Repositories
        bind:
          create_host_path: true
      - type: bind
        source: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\Logs
        target: /app/Logs
        bind:
          create_host_path: true
  frontend:
    build:
      context: C:\Projects\C#\WotBriefingRoom\WotBriefingRoom\FrontEnd
      dockerfile: Dockerfile
    container_name: wot-frontend
    depends_on:
      backend:
        condition: service_started
        required: true
    networks:
      default: null
    ports:
      - mode: ingress
        target: 80
        published: "3000"
        protocol: tcp
  mongo:
    container_name: wot-mongo
    image: mongo:6
    networks:
      default: null
    ports:
      - mode: ingress
        target: 27017
        published: "27017"
        protocol: tcp
    volumes:
      - type: volume
        source: mongo-data
        target: /data/db
        volume: {}
networks:
  default:
    name: dockercompose434550024337170792_default
volumes:
  mongo-data:
    name: dockercompose434550024337170792_mongo-data