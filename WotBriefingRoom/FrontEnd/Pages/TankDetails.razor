            <!-- 2-es csoport -->
            <!-- Rich Select demó: kép balra + 10 sor szöveg jobbra -->
            <div class="group">
                <div class="rich-select @(isAmmoOpen ? "open" : "")" data-name="ammo">
                    <button class="rs-trigger"
                            type="button"
                            aria-haspopup="listbox"
                            aria-expanded="@isAmmoOpen.ToString().ToLower()"
                            @onclick="ToggleAmmoSelect">
                        <img src="@GetSelectedAmmoImage()" alt="">
                    </button>

                    <input type="hidden" name="ammo" value="@selectedAmmoType" />

                    @if (isAmmoOpen)
                    {
                        <div class="rs-panel" role="listbox" @onclick:stopPropagation="true">
                            @if (tank?.Ammo != null)
                            {
                                @foreach (var ammo in tank.Ammo)
                                {
                                    <button type="button"
                                            class="rs-option"
                                            role="option"
                                            @onclick="() => SelectAmmo(ammo)">
                                        <img src="@GetAmmoImage(ammo.Type)" alt="">
                                        <div class="rs-text">
                                            <div class="rs-title">@GetAmmoTitle(ammo.Type)</div>
                                            <div>Damage: @GetAmmoDamage(ammo)</div>
                                            <div>Penetration: @GetAmmoPenetration(ammo)</div>
                                        </div>
                                    </button>
                                }
                            }
                        </div>
                    }
