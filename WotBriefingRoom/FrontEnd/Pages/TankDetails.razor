    private static string NormalizeButtonId(string? id)
    {
        return string.IsNullOrWhiteSpace(id) ? string.Empty : id.Trim();
    }

    private CrewSkills? GetCrewSkillByLabel(string? ariaLabel)
    {
        var normalized = NormalizeButtonId(ariaLabel);

        if (string.IsNullOrWhiteSpace(normalized) || crewSkills == null)
            return null;

        if (!int.TryParse(normalized, out var id))
            return null;

        return crewSkills.FirstOrDefault(x => x.Id == id);
    }

