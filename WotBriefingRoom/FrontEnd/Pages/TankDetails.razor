                        <tr><td>Rate of fire</td><td>@DisplayFireRate(tank)</td></tr>
                        <tr><td>DPM</td><td>@DisplayDpm(tank)</td></tr>
                        <tr><td>AVG Damage</td><td>@DisplayAmmoDamage(tank)</td></tr>
                        <tr><td>Penetration</td><td>@DisplayAmmoPenetration(tank)</td></tr>
                        <tr><td>Reload time</td><td>@DisplayGunReloadTime(tank)</td></tr>
                        <tr><td>Aim time</td><td>@DisplayGunAimingTime(tank)</td></tr>
                        <tr><td>Dispersion</td><td>@DisplayGunDispersionRadius(tank)</td></tr>
                        <tr><td>Damaged Dispersion</td><td>@DisplayGunDispersionWhileDamaged(tank)</td></tr>
                        <tr><td>Moving Dispersion</td><td>@DisplayFirstChassisDispersion(tank)</td></tr>
                        <tr><td>Turret Traverse Dispersion</td><td>@DisplayGunDispersionTurretRotation(tank)</td></tr>
                        <tr><td>After Shot</td><td>@DisplayGunDispersionAfterShot(tank)</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="card">
            <h3>Mobility</h3>
            <div class="inner">
                <table>
                    <thead>
                    </thead>
                    <tbody>
                        <tr><td>Top speed</td><td>@DisplaySpeed(tank, true)</td></tr>
                        <tr><td>Engine Power</td><td>@WithUnit(tank?.EnginePower, " hp")</td></tr>
                        <tr><td>Reverse speed</td><td>@DisplaySpeed(tank, false)</td></tr>
                        <tr><td>Rotation Speed</td><td>@DisplayRotationSpeed(tank)</td></tr>
                        <tr><td>Terrain Resistance</td><td>@DisplayFirstChassisValue(tank, c => c.TerrainResistance)</td></tr>
                        <tr><td>Gun min pitch</td><td>@DisplayGunMinPitch(tank)</td></tr>
                        <tr><td>Gun max pitch</td><td>@DisplayGunMaxPitch(tank)</td></tr>
                        <tr><td>Gun traverse range</td><td>@DisplayFirstGunValue(tank, g => g.TurretYawLimits)</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="card">
            <h3>Survivability</h3>
            <div class="inner">
                <table>
                    <thead>
                    </thead>
                    <tbody>
                        <tr><td>HP</td><td>@Fmt(tank?.HP)</td></tr>
                        <tr><td>Hull health</td><td>@Fmt(tank?.HullHP)</td></tr>
                        <tr><td>Weight</td><td>@DisplayTotalWeight(tank)</td></tr>
                        <tr><td>Max Load</td><td>@DisplayFirstChassisValue(tank, c => c.MaxLoad, " kg")</td></tr>
                        <tr><td>Ammo rack health</td><td>@Fmt(tank?.Hull?.AmmoBayHealth?.MaxHealth)</td></tr>
                        <tr><td>Turret Rotator Health</td><td>@DisplayTurretRotatorMaxHealth(tank)</td></tr>
                        <tr><td>Hull armor</td><td>@DisplayHullArmor(tank, "armor_1")</td></tr>
                        <tr><td>Turret armor</td><td>@DisplayTurretArmor(tank, "armor_1")</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="card">
            <h3>Visibility / Crew</h3>
            <div class="inner">
                <table>
                    <thead>
                    </thead>
                    <tbody>
