    private string GetCrewSkillTitle(string? ariaLabel, string fallbackTitle)
    {
        var normalized = NormalizeButtonId(ariaLabel);
        var skill = GetCrewSkillByLabel(normalized);

        if (skill == null)
            return fallbackTitle;

        return $"Skill {normalized}";
    }

    private void SelectGroupButton(string groupName, string id)
    {
        var normalizedGroup = NormalizeButtonId(groupName);
        var normalizedId = NormalizeButtonId(id);

        if (string.IsNullOrWhiteSpace(normalizedGroup) || string.IsNullOrWhiteSpace(normalizedId))
            return;

        if (activeGroupButtons.TryGetValue(normalizedGroup, out var current) && current == normalizedId)
        {
            activeGroupButtons.Remove(normalizedGroup);
        }
        else
        {
            activeGroupButtons[normalizedGroup] = normalizedId;
        }
    }

    private bool IsGroupActive(string groupName, string id)
    {
        var normalizedGroup = NormalizeButtonId(groupName);
        var normalizedId = NormalizeButtonId(id);

        return activeGroupButtons.TryGetValue(normalizedGroup, out var current)
            && current == normalizedId;
    }

    private void ToggleMatrixButton(string id)
    {
        var normalizedId = NormalizeButtonId(id);

        if (string.IsNullOrWhiteSpace(normalizedId))
            return;

        if (!activeMatrixButtons.Add(normalizedId))
            activeMatrixButtons.Remove(normalizedId);
    }

    private bool IsMatrixActive(string id)
    {
        var normalizedId = NormalizeButtonId(id);

        return !string.IsNullOrWhiteSpace(normalizedId)
            && activeMatrixButtons.Contains(normalizedId);
    }

    private IEnumerable<CrewSkills> GetActiveMatrixSkills()
    {
        if (crewSkills == null || activeMatrixButtons.Count == 0)
            return Enumerable.Empty<CrewSkills>();

        return crewSkills.Where(s => activeMatrixButtons.Contains(s.Id.ToString()));
    }

    private string GetActiveMatrixSkillIds()
    {
        return activeMatrixButtons.Count == 0
            ? "-"
            : string.Join(", ", activeMatrixButtons.OrderBy(x => x));
    }

