    private  string DisplayGunInvisibilityAtShotMoving(FrontEndData? tank)
    {
        var gun = GetSelectedGun(tank);

        var shot = ParseDouble(gun?.InvisibilityFactorAtShot);
        var moving = ParseDouble(tank?.Invisibility?.Moving);

        if (shot == null || moving == null)
            return "-";

        var result = shot.Value * (moving.Value * 57);
        return result.ToString("0.###", CultureInfo.InvariantCulture);
    }

