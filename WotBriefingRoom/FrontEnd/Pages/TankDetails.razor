    private static string DisplayTotalWeight(FrontEndData? tank)
    {
        if (tank == null)
            return "-";

        var total =
            (ParseDouble(tank.Hull?.Weight) ?? 0) +
            tank.GunWeight +
            tank.EngineWeight +
            (ParseDouble(tank.Chassis?.Values.FirstOrDefault()?.Weight) ?? 0);

        return total.ToString("0.00", CultureInfo.InvariantCulture) + " kg";
    }

