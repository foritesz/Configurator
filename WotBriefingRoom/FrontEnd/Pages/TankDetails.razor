@page "/tanks/{id:int}"
@using System.Net.Http.Json
@using DTO
@using BonusModels.BonusModels   @* <-- tedd át a bónusz modelleket is a DTO projektbe *@
@using DTO.TanksModels
@using System.Globalization
@using FrontEnd.Services.CrewServices
@inject HttpClient Http
@inject CrewSkillService CrewSkillService



<!-- ======= Canvas szekció ======= -->
<section class="canvas-wrap">
    <canvas id="scene"></canvas>
    <div id="hudLayer" class="hud-layer" aria-hidden="false"></div>
</section>

<!-- Mobil: szekciók (Szűrők + Mátrix) megjelenítése/elrejtése -->
<button id="sectionsToggle" class="mobile-sections-toggle i-category" type="button" aria-controls="controlsRow" aria-expanded="false">Filter</button>

<!-- ======= SZŰRŐK / KONTROLLOK (ÚJ) ======= -->
<section id="controlsRow" class="controls-row">
    <section class="filters" aria-label="Szűrők">
        <div class="filters-top" style="justify-content:center; flex-wrap:wrap;">
            <!-- 4-es csoport -->
            <div class="group">
                <select class="icon-select i-susp" @bind="selectedGunKey"
                        aria-label="Gun" style="background-image:url('/images/moduls/gun.png')">
                    @if (tank?.Guns != null)
                    {
                        @foreach (var gun in tank.Guns.Keys)
                        {
                            <option value="@gun">@gun</option>
                        }
                    }
                </select>

                <select class="icon-select i-country" @bind="selectedTurretKey"
                        aria-label="Turret" style="background-image:url('/images/moduls/towerBig.png')">
                    @if (tank?.Turrets0 != null)
                    {
                        @foreach (var turret in tank.Turrets0.Keys)
                        {
                            <option value="@turret">@turret</option>
                        }
                    }
                </select>

                <select class="icon-select i-year" @bind="selectedEngineKey"
                        aria-label="Engine" style="background-image:url('/images/moduls/engineBig.png')">
                    @if (tank?.Engines != null)
                    {
                        @foreach (var engine in tank.Engines.Keys)
                        {
                            <option value="@engine">@engine</option>
                        }
                    }
                </select>

                <select class="icon-select i-state" @bind="selectedChassisKey"
                        aria-label="Chassis" style="background-image:url('/images/moduls/chassis.png')">
                    @if (tank?.Chassis != null)
                    {
                        @foreach (var chassis in tank.Chassis.Keys)
                        {
                            <option value="@chassis">@chassis</option>
                        }
                    }
                </select>
            </div>
            <!-- 3-as csoport -->
            <div class="group">
                <div class="rich-select" data-name="ammo">
                    <button class="rs-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
                        <div class="rs-img-stack">
                            <img src="/images/directives/boosterSign.png" class="bg" alt="">
                            <img src="/images/equipments/improvedVentilation_tier2.png" class="fg" alt="">
                        </div>
                    </button>
                    <div class="rs-panel" role="listbox">
                        <div class="rs-option" role="option" data-value="ap">
                            <img src="/images/ammo/ARMOR_PIERCING.png" alt="">
                            <div class="rs-text">
                                <div class="rs-title">Armor Piercing (AP)</div>
                                Nagy sűrűségű, kemény lövedékmag.


                                • Páncélátütés jó közepes távon.


                                • Olcsóbb, széles körben elérhető.


                                • Minimális robbanó hatás.


                                • Foglalat: 120 mm L/44–L/55.


                                • Ajánlott: alap célpontok ellen.


                                • Korlát: ferde páncélon lepattanás.


                                • Megjegyzés: KE csapás, nincs hőhatás.
                            </div>
                        </div>
                        <div class="rs-option" role="option" data-value="apcr">
                            <img src="/images/ammo/APCR.png" alt="">
                            <div class="rs-text">
                                <div class="rs-title">APCR</div>
                                Nagy kezdősebesség, kemény volfrám mag.


                                • Kiváló átütés rövid/közepes távolságon.


                                • Gyors, lapos röppálya.


                                • Távolsággal csökkenő hatás.


                                • Korlát: reaktív páncél ellen mérsékeltebb.
                            </div>
                        </div>
                        <div class="rs-option" role="option" data-value="heat">
                            <img src="/images/ammo/HEAT.png" alt="">
                            <div class="rs-text">
                                <div class="rs-title">HEAT</div>
