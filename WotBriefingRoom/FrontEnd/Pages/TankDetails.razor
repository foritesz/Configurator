    </section>

    <!-- Matrix Section (jobb oldalt) -->
    <section class="matrix" aria-label="Ikon mátrix">
        <div class="matrix-grid">

            <div class="matrix-row">
                <div class="icon-cell i-susp" title="Kategória" style="background-image:url('/images/crew/silhouette_mask.png')"></div>

                <button type="button"
                        class="icon-btn i-country @(IsMatrixActive("102") ? "active" : "")"
                        aria-label="102"
                        @onclick='() => ToggleMatrixButton(" 102")'
                        style="background-image:url('/images/crew/brotherhood.png')">
                </button>

                <button type="button"
                        class="icon-btn i-year @(IsMatrixActive("repair") ? "active" : "")"
                        aria-label="Év"
                        @onclick='() => ToggleMatrixButton(" repair")'
                        style="background-image:url('/images/crew/repair.png')">
                </button>

                <button type="button"
                        class="icon-btn i-state @(IsMatrixActive("camouflage") ? "active" : "")"
                        aria-label="Állapot"
                        @onclick='() => ToggleMatrixButton(" camouflage")'
                        style="background-image:url('/images/crew/icon_perk_camouflage.png')">
                </button>
            </div>

            <div class="matrix-row">
                <div class="icon-cell i-armor" title="Védelem" style="background-image:url('/images/crew/commander.png')"></div>

                <button type="button"
                        class="icon-btn i-fcs @(IsMatrixActive("101") ? "active" : "")"
