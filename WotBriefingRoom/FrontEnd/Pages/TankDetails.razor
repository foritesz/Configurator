    private static ChassisData? GetFirstChassis(FrontEndData? tank)
    {
        return tank?.Chassis?.Values.FirstOrDefault();
    }

    private static string DisplayFirstChassisValue(FrontEndData? tank, Func<ChassisData, object?> selector, string unit = "")
    {
        var chassis = GetFirstChassis(tank);
        if (chassis == null)
            return "-";

        var formatted = Fmt(selector(chassis));
        return formatted == "-" ? "-" : formatted + unit;
    }

    private static string DisplayFirstChassisDispersion(FrontEndData? tank)
    {
        var chassis = GetFirstChassis(tank);
        if (chassis == null || chassis.ShotDispersionFactors == null)
            return "-";

        var move = Fmt(chassis.ShotDispersionFactors.VehicleMovement);
        var rot = Fmt(chassis.ShotDispersionFactors.VehicleRotation);

        return move == "-" && rot == "-" ? "-" : move + " / " + rot;
    }

    private static string DisplaySpeed(FrontEndData? tank, bool forward)
    {
        var value = forward ? tank?.SpeedLimits?.Forward : tank?.SpeedLimits?.Backward;
        var formatted = Fmt(value);
        return formatted == "-" ? "-" : formatted + " km/h";
    }

    private static string DisplayArmorValue(object? value)
    {
        if (value == null)
            return "-";

        if (value is string s)
            return string.IsNullOrWhiteSpace(s) ? "-" : s;

        if (value is IDictionary<string, object> dict && dict.Count > 0)
            return string.Join(", ", dict.Select(x => x.Key + ": " + Fmt(x.Value)));

        return value.ToString() ?? "-";
    }

    private static string DisplayHullArmor(FrontEndData? tank, string key)
    {
        if (tank?.Hull?.Armor != null && tank.Hull.Armor.TryGetValue(key, out var value))
            return DisplayArmorValue(value);

        return "-";
    }

