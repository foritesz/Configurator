@code {
    [Parameter] public int id { get; set; }

    private FrontEndData? tank;
    private List<Consumables>? consumables;
    private List<Equipments>? equipments;
    private List<CrewSkills>? crewSkills;
    private List<FiledModefication>? fieldMods;

    private double modulStatConverter = 0.959;

    private string selectedGunKey = "Összes";
    private string selectedTurretKey = "Összes";
    private string selectedEngineKey = "Összes";
    private string selectedChassisKey = "Összes";
    private string selectedAmmoType = string.Empty;
    private Dictionary<string, string> activeGroupButtons = new();
    private HashSet<string> activeMatrixButtons = new();
    private bool isAmmoOpen;

    private ITankMechanic? mechanic;

    private TankMechanicContext MechanicContext => new()
    {
        Tank = tank,
        SelectedGunKey = selectedGunKey,
        SelectedTurretKey = selectedTurretKey,
        SelectedEngineKey = selectedEngineKey,
        SelectedChassisKey = selectedChassisKey,
        SelectedAmmoType = selectedAmmoType,
        ActiveMatrixButtons = activeMatrixButtons
    };


    protected override async Task OnInitializedAsync()
    {
        tank = await Http.GetFromJsonAsync<FrontEndData>($"api/tanks/{id}");
        consumables = await Http.GetFromJsonAsync<List<Consumables>>("api/bonuses/consumables");
        equipments = await Http.GetFromJsonAsync<List<Equipments>>("api/bonuses/equipments");
        crewSkills = await Http.GetFromJsonAsync<List<CrewSkills>>("api/bonuses/crewskills");
        fieldMods = await Http.GetFromJsonAsync<List<FiledModefication>>("api/bonuses/fieldmods");

        CrewSkillService.SetCrewSkills(crewSkills);

        if (tank?.Guns != null && tank.Guns.Count > 0)
            selectedGunKey = tank.Guns.Keys.First();

        if (tank?.Turrets0 != null && tank.Turrets0.Count > 0)
            selectedTurretKey = tank.Turrets0.Keys.First();

        if (tank?.Engines != null && tank.Engines.Count > 0)
            selectedEngineKey = tank.Engines.Keys.First();

        if (tank?.Chassis != null && tank.Chassis.Count > 0)
            selectedChassisKey = tank.Chassis.Keys.First();

        if (tank?.Ammo != null && tank.Ammo.Count > 0)
            selectedAmmoType = tank.Ammo[0].Type ?? string.Empty;

        mechanic = CreateMechanic(tank);
    }

    private RenderFragment RenderList<T>(
        List<T>? list,
        string emptyText,
        Func<T, RenderFragment> item) => __builder =>
    {
        if (list is null)
        {
            __builder.AddContent(0, (RenderFragment)(b => b.AddContent(1, "Betöltés...")));
            return;
        }

        if (list.Count == 0)
        {
            __builder.AddContent(0, (RenderFragment)(b => b.AddContent(1, emptyText)));
            return;
        }

        __builder.OpenElement(0, "ul");
        int seq = 1;
        foreach (var it in list)
        {
            __builder.OpenElement(seq++, "li");
            __builder.AddContent(seq++, item(it));
            __builder.CloseElement();
        }
        __builder.CloseElement();
    };

    private static double? ParseDouble(object? value)
    {
        if (value == null)
            return null;

        if (value is string s)
        {
            if (string.IsNullOrWhiteSpace(s))
                return null;

            if (double.TryParse(
                s,
                NumberStyles.Any,
                CultureInfo.InvariantCulture,
                out var result))
            {
                return result;
            }

            return null;
        }

        try
        {
            return Convert.ToDouble(value, CultureInfo.InvariantCulture);
        }
        catch
        {
            return null;
        }
    }

    private static string MultiplyAndFormat(
        object? value,
        double multiplier,
        string unit = "",
        string format = "0.00")
    {
        var parsed = ParseDouble(value);

        if (parsed == null)
            return "-";

        var result = parsed.Value * multiplier;

        return result.ToString(format, CultureInfo.InvariantCulture) + unit;
    }

    private static string Fmt(object? value)
    {
        if (value is null) return "-";

        if (value is string s)
            return string.IsNullOrWhiteSpace(s) ? "-" : s;

        return value.ToString() ?? "-";
    }

    private static string WithUnit(object? value, string unit)
    {
        var formatted = Fmt(value);
        return formatted == "-" ? "-" : formatted + unit;
    }

    private static string DisplayTierType(FrontEndData? tank)
    {
        if (tank is null) return "-";

        var level = Fmt(tank.Level);
        var type = Fmt(tank.Type);

        return level == "-" && type == "-" ? "-" : level + " / " + type;
    }

    private static string DisplayFirstKey(Dictionary<string, object>? data)
    {
        return data != null && data.Count > 0
            ? data.Keys.FirstOrDefault() ?? "-"
            : "-";
    }

    private static AmmoData? GetPrimaryAmmo(FrontEndData? tank)
    {
        return tank?.Ammo?.FirstOrDefault();
    }

    private  string DisplayAmmoDamage(FrontEndData? tank)
    {
        var ammo = GetSelectedAmmo(tank);
        if (ammo == null || ammo.Damage == null || ammo.Damage.Count < 2)
            return "-";

        return ammo.Damage[1].ToString();
