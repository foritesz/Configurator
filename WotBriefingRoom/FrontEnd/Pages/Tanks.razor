@page "/tanks"
@using FrontEnd.Services
@using DTO
@inject TanksApi Api

<div class="container">

    <section class="filters @(filtersOpen ? "open" : "")" id="filters">
        <div class="filters-header">
            <span class="filters-title">Szűrők</span>

            <button class="btn btn-icon mobile-toggle"
                    type="button"
                    aria-expanded="@filtersOpen.ToString().ToLower()"
                    aria-controls="filterGrid"
                    title="Szűrők megjelenítése/elrejtése"
                    @onclick="ToggleFilters">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="3" y="6" width="18" height="2" rx="1" />
                    <rect x="3" y="11" width="18" height="2" rx="1" />
                    <rect x="3" y="16" width="18" height="2" rx="1" />
                </svg>
            </button>
        </div>

        <div class="filters-grid" id="filterGrid">
        <!-- 2 db 12x12 ikonos gomb -->
            <div class="filter-group" aria-label="Alapeszközök">
              <button class="btn btn-icon" title="Alapértelmezett">
                <!-- target -->
                <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4"/></svg>
              </button>
              <button class="btn btn-icon" title="Törlés">
                <!-- seprű -->
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 16l3-3 7 7-3 3z"/><path d="M14 6l4-4 4 4-4 4z"/><path d="M6 14l8-8 4 4-8 8z" fill="none" stroke="currentColor" stroke-width="2"/></svg>
              </button>
            </div>
       
        <span class="divider" aria-hidden="true"></span>

        <!-- 5 db 12x12 ikonos gomb -->
        <div class="filter-group" aria-label="Típusok">
          <button class="btn btn-icon" title="Könnyű tank">
            <svg viewBox="0 0 24 24" aria-hidden="true"><polygon points="12,4 20,20 4,20"/></svg>
          </button>
          <button class="btn btn-icon" title="Közepes tank">
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="6"/></svg>
          </button>
          <button class="btn btn-icon" title="Nehéz tank">
            <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
          </button>
          <button class="btn btn-icon" title="Páncélvadász">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12h16" stroke="currentColor" stroke-width="2"/><path d="M8 8l-4 4 4 4"/></svg>
          </button>
          <button class="btn btn-icon" title="Önjáró löveg">
            <svg viewBox="0 0 24 24" aria-hidden="true"><polygon points="12,2 22,12 12,22 2,12"/></svg>
          </button>
        </div>
        <span class="divider" aria-hidden="true"></span>

        <!-- 10 db 50x12 gomb római számmal -->
        <div class="filter-group" aria-label="Tier">
          <button class="btn btn-roman small-size" data-tier="I">I</button>
          <button class="btn btn-roman small-size" data-tier="II">II</button>
          <button class="btn btn-roman small-size" data-tier="III">III</button>
          <button class="btn btn-roman small-size" data-tier="IV">IV</button>
          <button class="btn btn-roman small-size" data-tier="V">V</button>
          <button class="btn btn-roman small-size" data-tier="VI">VI</button>
          <button class="btn btn-roman small-size" data-tier="VII">VII</button>
          <button class="btn btn-roman small-size" data-tier="VIII">VIII</button>
          <button class="btn btn-roman small-size" data-tier="IX">IX</button>
          <button class="btn btn-roman small-size" data-tier="X">X</button>
          <button class="btn btn-roman small-size" data-tier="XI">XI</button>
        </div>
        <span class="divider" aria-hidden="true"></span>

        <!-- 11 db 12x12 ikonos gomb -->
        <div class="filter-group" aria-label="Egyéb">
          <button class="btn btn-icon" title="Villám"><svg viewBox="0 0 24 24"><polygon points="13,2 4,14 12,14 11,22 20,10 12,10"/></svg></button>
          <button class="btn btn-icon" title="Pajzs"><svg viewBox="0 0 24 24"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/></svg></button>
          <button class="btn btn-icon" title="Célkereszt"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8" fill="none" stroke="currentColor"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/></svg></button>
          <button class="btn btn-icon" title="Csillag"><svg viewBox="0 0 24 24"><path d="M12 3l3 6 6 1-4.5 4.3L18.5 21 12 17.8 5.5 21l1.9-6.7L3 10l6-1z"/></svg></button>
          <button class="btn btn-icon" title="Fogaskerék"><svg viewBox="0 0 24 24"><path d="M12 8a4 4 0 100 8 4 4 0 000-8zm-8 4l2-1 1-2 2-1 1-2h4l1 2 2 1 1 2 2 1v4l-2 1-1 2-2 1-1 2h-4l-1-2-2-1-1-2-2-1z"/></svg></button>
          <button class="btn btn-icon" title="Levél"><svg viewBox="0 0 24 24"><path d="M3 6h18v12H3z" fill="none" stroke="currentColor"/><path d="M3 6l9 7 9-7"/></svg></button>
          <button class="btn btn-icon" title="Lomb"><svg viewBox="0 0 24 24"><path d="M12 2C9 5 5 7 4 12c0 5 4 8 8 8s8-3 8-8C19 7 15 5 12 2z"/></svg></button>
          <button class="btn btn-icon" title="Kereszt"><svg viewBox="0 0 24 24"><path d="M11 3h2v7h7v2h-7v9h-2v-9H4v-2h7z"/></svg></button>
          <button class="btn btn-icon" title="Kulcs"><svg viewBox="0 0 24 24"><circle cx="8" cy="12" r="3"/><path d="M11 12h10v3h-3v3h-3v-3h-4z"/></svg></button>
          <button class="btn btn-icon" title="Csepp"><svg viewBox="0 0 24 24"><path d="M12 2s6 6 6 11a6 6 0 11-12 0c0-5 6-11 6-11z"/></svg></button>
          <button class="btn btn-icon" title="Koponya"><svg viewBox="0 0 24 24"><circle cx="9" cy="11" r="1.5"/><circle cx="15" cy="11" r="1.5"/><path d="M12 3c5 0 9 4 9 9 0 3-2 5-4 6v3H7v-3c-2-1-4-3-4-6 0-5 4-9 9-9z"/></svg></button>
        </div>
        <span class="divider" aria-hidden="true"></span>

        <div class="filter-group search-group" id="filterGrid">
                <div class="filter-group search-group" aria-label="Keresés">
                    <input type="text"
                           class="search-input"
                           @bind="search"
                           @bind:event="oninput"
                           placeholder="Keresés tank névre..." />
                    <button class="btn search-btn" type="button" @onclick="Reload">Keresés</button>
                    <button class="btn" type="button" @onclick="ClearSearch">Törlés</button>
                </div>
             </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert-box error mt-3">@errorMessage</div>
    }
    else if (loading)
    {
        <div class="alert-box info mt-3">Betöltés...</div>
    }
    else
    {
        <section class="table-wrap">
            <div class="table-scroll">
                <table class="tank-table">
                    <thead>
                        <tr>
                            <th>Nation</th>
                            <th>Type</th>
                            <th>Tier</th>
                            <th>Icon</th>
                            <th>Name</th>
                            <th>HP</th>
                            <th>Gun</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (tanks.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="empty-cell">Nincs találat.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var tank in tanks)
                            {
                                <tr>
                                    <td class="cell-nation" data-label="Nation">
                                        <span class="text-muted">@DisplayNation(tank)</span>
                                    </td>

                                    <td class="cell-type" data-label="Type">
                                        <span class="type-badge">@DisplayType(tank)</span>
                                    </td>

                                    <td class="cell-tier" data-label="Tier">
                                        @DisplayTier(tank)
                                    </td>

                                    <td class="cell-icon" data-label="Icon">
                                        @if (!string.IsNullOrWhiteSpace(tank.ContourImage))
                                        {
                                            <img src="@tank.ContourImage"
                                                 alt="@tank.Name"
                                                 class="tank-icon-img" />
                                        }
                                        else
                                        {
                                            <div class="tank-icon-placeholder">—</div>
                                        }
                                    </td>

                                    <td class="cell-name" data-label="Name">
                                        <a class="name-link" href="/tanks/@tank.TankId">@tank.Name</a>
                                    </td>

                                    <td data-label="DPM">
                                        @DisplayDpm(tank)
                                    </td>

                                    <td data-label="Top Speed">
                                        @DisplaySpeed(tank)
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-footer">
                <div class="table-summary">
                    Összes találat: @totalCount | Oldal: @currentPage / @totalPages
                </div>

                <nav class="paginator" aria-label="Lapozás">
                    <button class="page-btn" @onclick="FirstPage" disabled="@(currentPage == 1)">«</button>
                    <button class="page-btn" @onclick="PrevPage" disabled="@(currentPage == 1)">‹</button>


                @for (int i = StartPageAdjusted; i <= EndPageAdjusted; i++)
                {
                    var page = i;
                    <button class="page-btn @(page == currentPage ? "active" : "")"
                            aria-current="@(page == currentPage ? "page" : null)"
                            @onclick="() => GoToPage(page)">
                        @(page)
                    </button>
                }

                    <button class="page-btn" @onclick="NextPage" disabled="@(currentPage == totalPages || totalPages == 0)">›</button>
                    <button class="page-btn" @onclick="LastPage" disabled="@(currentPage == totalPages || totalPages == 0)">»</button>
                </nav>

                <div class="page-size">
                    <label for="pageSize" class="muted">Oldal méret:</label>
                    <select id="pageSize" @onchange="OnPageSizeChanged">
                        <option value="10" selected="@(pageSize == 10)">10</option>
                        <option value="25" selected="@(pageSize == 25)">25</option>
                        <option value="50" selected="@(pageSize == 50)">50</option>
                        <option value="100" selected="@(pageSize == 100)">100</option>
                    </select>
                </div>
            </div>
        </section>
    }
</div>

@code {
    private List<FrontEndData> tanks = new();
    private int currentPage = 1;
    private int pageSize = 25;
    private int totalPages = 1;
    private int totalCount = 0;
    private string? search;
    private bool filtersOpen;
    private bool loading;
    private string? errorMessage;
    private int windowSize = 3;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        errorMessage = null;

        try
        {
            var result = await Api.GetTanksAsync(currentPage, pageSize, search);

            tanks = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = $"Hiba a tankok betöltésekor: {ex.Message}";
            tanks = new();
            totalPages = 1;
            totalCount = 0;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Reload()
    {
        currentPage = 1;
        await Load();
    }

    private async Task ClearSearch()
    {
        search = null;
        currentPage = 1;
        await Load();
    }

    private void ToggleFilters()
    {
        filtersOpen = !filtersOpen;
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > totalPages) return;

        currentPage = page;
        await Load();
    }

    private async Task FirstPage()
    {
        if (currentPage == 1) return;

        currentPage = 1;
        await Load();
    }

    private async Task PrevPage()
    {
        if (currentPage <= 1) return;

        currentPage--;
        await Load();
    }

    private async Task NextPage()
    {
        if (currentPage >= totalPages) return;

        currentPage++;
        await Load();
    }

    private async Task LastPage()
    {
        if (totalPages <= 0 || currentPage == totalPages) return;

        currentPage = totalPages;
        await Load();
    }

    private int StartPage =>
        Math.Max(1, currentPage - windowSize / 2);

    private int EndPage =>
        Math.Min(totalPages, StartPage + windowSize - 1);

    private int StartPageAdjusted
    {
        get
        {
            var start = Math.Max(1, currentPage - windowSize / 2);

            if (start + windowSize - 1 > totalPages)
            {
                start = Math.Max(1, totalPages - windowSize + 1);
            }

            return start;
        }
    }

    private int EndPageAdjusted =>
        Math.Min(totalPages, StartPageAdjusted + windowSize - 1);

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var newSize))
        {
            pageSize = newSize;
            currentPage = 1;
            await Load();
        }
    }

    private static string DisplayNation(FrontEndData tank)
    {
        var prop = tank.GetType().GetProperty("Nation");
        return prop?.GetValue(tank)?.ToString() ?? "-";
    }

    private static string DisplayType(FrontEndData tank)
    {
        return tank.Type?.ToString() ?? "-";
    }

    private static string DisplayTier(FrontEndData tank)
    {
        return tank.Level.ToString() ?? "-";
    }

    private static string DisplaySpeed(FrontEndData tank)
    {
        return tank.SpeedLimits.Forward.ToString() ?? "-";
    }

    private static string DisplayDpm(FrontEndData tank)
    {
        if (tank.Ammo != null &&
            tank.Ammo.Count > 0 &&
            tank.Ammo[0].Damage != null &&
            tank.Ammo[0].Damage.Count > 1)
        {
            var damage = tank.Ammo[0].Damage[1]; // második érték
            var dpm = damage * tank.FireRate;

            return dpm.ToString("0"); // kerekítve
        }

        return "-";
    }
}